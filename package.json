{
  "name": "@ojfbot/daily-logger",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "generate": "tsx src/index.ts",
    "generate:dry": "DRY_RUN=true tsx src/index.ts",
    "report": "tsx src/report.ts",
    "report:dry": "DRY_RUN=true tsx src/report.ts",
    "clean": "tsx src/clean.ts",
    "clean:dry": "DRY_RUN=true tsx src/clean.ts",
    "backfill": "tsx src/backfill-tags.ts",
    "backfill:refs": "tsx src/backfill-code-refs.ts",
    "build:api": "tsx src/build-api.ts",
    "dev": "tsx src/build-api.ts && cd packages/frontend && pnpm dev",
    "type-check": "tsc --noEmit",
    "lint": "eslint 'src/**/*.ts'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.0",
    "@vercel/node": "^5.6.22",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/marked": "^6.0.0",
    "@types/node": "^22.9.0",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "marked": "^17.0.5",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.57.2",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "packageManager": "pnpm@9.15.4"
}
